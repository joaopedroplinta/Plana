# Copie para `.env` na raiz do projeto antes de rodar
# `docker compose -f docker-compose.prod.yml up -d --build`.
# Veja o guia completo em DEPLOY.md.

# ---- Domínios (a Caddy emite HTTPS automático via Let's Encrypt pra eles) ----
DOMAIN_API=api.seudominio.com.br
DOMAIN_WEB=seudominio.com.br

# ---- Banco de dados ----
POSTGRES_DB=agendamentos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# ---- Laravel ----
APP_NAME="Plana"
APP_ENV=production
APP_DEBUG=false
# Gere com: docker compose -f docker-compose.prod.yml run --rm api php artisan key:generate --show
APP_KEY=
APP_URL=https://api.seudominio.com.br
FRONTEND_URL=https://seudominio.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

DB_CONNECTION=pgsql
DB_PORT=5432
DB_DATABASE=agendamentos
DB_USERNAME=postgres
DB_PASSWORD=troque-por-uma-senha-forte

SESSION_DRIVER=database
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=predis
REDIS_PORT=6379
REDIS_PASSWORD=null

# SMTP real — sem isso, e-mails transacionais (confirmação, lembrete, etc.) não saem
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@seudominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# MercadoPago (credenciais de produção, não de teste)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# Segurança
SANCTUM_TOKEN_EXPIRATION=10080
CORS_ALLOWED_ORIGINS=https://seudominio.com.br
AUTH_RATE_LIMIT_PER_MINUTE=5

# ---- Next.js (usadas em build-time pela imagem web) ----
NEXT_PUBLIC_API_URL=https://api.seudominio.com.br/api/v1
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
